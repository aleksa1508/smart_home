<UserControl x:Class="Client.DevicesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Client"
             mc:Ignorable="d" 
              d:DesignHeight="370" d:DesignWidth="610">
    <Grid Background="#1D3557">
        <Grid.ColumnDefinitions>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="8*"></RowDefinition>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Grid.ColumnSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition></ColumnDefinition>
                <ColumnDefinition></ColumnDefinition>
                <ColumnDefinition></ColumnDefinition>
                <ColumnDefinition></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <Button x:Name="kitchen_tab_button" Grid.Column="0" Content="Kitchen" Style="{StaticResource device_tab}" ToolTip="Kitchen" Click="kitchen_tab_button_Click"/>
            <Button x:Name="bedroom_tab_button" Grid.Column="1" Content="Bedroom" Style="{StaticResource device_tab}" ToolTip="Bedroom" Click="bedroom_tab_button_Click"/>
            <Button x:Name="living_room_tab_button" Grid.Column="2" Content="Living room" Style="{StaticResource device_tab}" ToolTip="Living room" Click="living_room_tab_button_Click"/>
            <Button x:Name="garage_tab_button" Grid.Column="3" Content="Garage" Style="{StaticResource device_tab}" ToolTip="Garage" Click="garage_tab_button_Click"/>
        </Grid>
            <StackPanel x:Name="DeviceStackPanel" Grid.Row="1" Grid.ColumnSpan="2" Orientation="Horizontal" Visibility="Collapsed">
                <Label Content="Device:" Foreground="White" FontSize="17" Margin="10,0,10,0"/>
                <ComboBox x:Name="DevicesComboBox"  Width="180" Height="30" Style="{StaticResource combo_box1}" ItemsSource="{Binding Devices}" DisplayMemberPath="Name"  SelectionChanged="DevicesComboBox_SelectionChanged"/>
            </StackPanel>
        <Grid x:Name="DeviceDetailsGrid" Grid.ColumnSpan="2" Grid.Row="2" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="4*"></RowDefinition>
        </Grid.RowDefinitions>
            
                <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal">
            <Label Content="Name:" Foreground="White" FontSize="17" Margin="10,12,15,0"/>
            <TextBox x:Name="NameTextBox" Style="{StaticResource txt_box}" IsEnabled="False" />
        </StackPanel>
        <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal">
            <Label Content="Port:" Foreground="White" FontSize="17" Margin="10,12,10,0"/>
            <TextBox x:Name="PortTextBox" Style="{StaticResource txt_box}" IsEnabled="False" />
        </StackPanel>
        <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal">
            <Label Content="Status:" Foreground="White" FontSize="17" Margin="10,12,15,0"/>
            <TextBox x:Name="StatusTextBox" Style="{StaticResource txt_box}" IsEnabled="False" />
        </StackPanel>
        <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal">
            <Label Content="Value:" Foreground="White" FontSize="17" Margin="10,12,0,0"/>
            <TextBox x:Name="ValueTextBox" Style="{StaticResource txt_box}" IsEnabled="False" />
        </StackPanel>
        <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Orientation="Vertical">
            <Label Content="Logs" Foreground="White" FontSize="17" Margin="10,0,0,0" />
            <DataGrid x:Name="LogsDataGrid" 
      Margin="5,5,5,0"
ColumnWidth="*"
HorizontalScrollBarVisibility="Disabled"
      Height="140"
      IsReadOnly="True"
      AutoGenerateColumns="False"
      Background="#1D3557"
      BorderThickness="0"
      GridLinesVisibility="None"
      HorizontalGridLinesBrush="#A8DADC"
      VerticalGridLinesBrush="#A8DADC"
      HeadersVisibility="Column"
      Foreground="White"
      CanUserSortColumns="True" >

                <!-- HEADER -->
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#457B9D"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="Padding" Value="10,5"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>

                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="DataGridColumnHeader">
                                    <Border
                    CornerRadius="5"
                    Background="{TemplateBinding Background}"
                    BorderBrush="#A8DADC"
                    BorderThickness="1"
                    Padding="{TemplateBinding Padding}">

                                        <ContentPresenter 
                        Content="{TemplateBinding Content}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"/>

                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <!-- ROW STYLE -->
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Background" Value="#2F4769"/>

                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="DataGridRow">
                                    <Border x:Name="RowBorder"
                        CornerRadius="8"
                        BorderBrush="#A8DADC"
                        BorderThickness="1,1,1,0" Height="25"
                        Background="{TemplateBinding Background}"
                        Opacity="0.95">

                                        <DataGridCellsPresenter/>

                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>

                        <!-- Hover -->
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3A5A80"/>
                            </Trigger>
                        </Style.Triggers>

                    </Style>
                </DataGrid.RowStyle>


                <!-- CELL -->
                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0,0,0,0"/>
                        <Setter Property="BorderBrush" Value="#A8DADC"/>
                        <Setter Property="Padding" Value="8,4"/>

                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="DataGridCell">
                                    <Border
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}">

                                        <ContentPresenter 
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </DataGrid.CellStyle>


                <!-- COLUMNS -->
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Date and Time" Width="3*" Binding="{Binding CreationDate}" />
                        <DataGridTextColumn Header="Log" Width="9*" Binding="{Binding Log}" />
                        <DataGridTextColumn Header="Username" Width="2*" Binding="{Binding Username}" />
                    </DataGrid.Columns>

            </DataGrid>
        </StackPanel>
        </Grid>
    </Grid>
</UserControl>
