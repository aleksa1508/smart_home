<UserControl x:Class="Client.UsersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Client"
             xmlns:helpers="clr-namespace:Client.Helpers"
             mc:Ignorable="d" 
             d:DesignHeight="370" d:DesignWidth="610">
    <Grid Background="#1D3557">
        <DataGrid x:Name="UsersDataGrid" 
          Margin="10,20,10,109"
    ColumnWidth="*"
    HorizontalScrollBarVisibility="Disabled"
          Height="240"
          ItemsSource="{Binding Users}"
          IsReadOnly="True"
          AutoGenerateColumns="False"
          Background="#1D3557"
          BorderThickness="0"
          GridLinesVisibility="None"
          HorizontalGridLinesBrush="#A8DADC"
          VerticalGridLinesBrush="#A8DADC"
          HeadersVisibility="Column"
          Foreground="White">

            <!-- HEADER -->
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#457B9D"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="Padding" Value="10,5"/>
                    <Setter Property="HorizontalContentAlignment" Value="Center"/>

                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="DataGridColumnHeader">
                                <Border
                        CornerRadius="5"
                        Background="{TemplateBinding Background}"
                        BorderBrush="#A8DADC"
                        BorderThickness="1"
                        Padding="{TemplateBinding Padding}">

                                    <ContentPresenter 
                            Content="{TemplateBinding Content}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"/>

                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </DataGrid.ColumnHeaderStyle>

            <!-- ROW STYLE -->
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="Background" Value="#2F4769"/>

                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="DataGridRow">
                                <Border x:Name="RowBorder"
                            CornerRadius="8"
                            BorderBrush="#A8DADC"
                            BorderThickness="1,1,1,0" Height="25"
                            Background="{TemplateBinding Background}"
                            Opacity="0.95">

                                    <DataGridCellsPresenter/>

                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>

                    <!-- Hover -->
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#3A5A80"/>
                        </Trigger>
                    </Style.Triggers>

                </Style>
            </DataGrid.RowStyle>


            <!-- CELL -->
            <DataGrid.CellStyle>
                <Style TargetType="DataGridCell">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="0,0,0,0"/>
                    <Setter Property="BorderBrush" Value="#A8DADC"/>
                    <Setter Property="Padding" Value="8,4"/>

                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="DataGridCell">
                                <Border
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}">

                                    <ContentPresenter 
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </DataGrid.CellStyle>


            <!-- COLUMNS -->
            <DataGrid.Columns>
                <DataGridTextColumn Header="Ime" Width="*" Binding="{Binding Ime}" />
                <DataGridTextColumn Header="Prezime" Width="*" Binding="{Binding Prezime}" />
                <DataGridTextColumn Header="Username" Width="*" Binding="{Binding KorisnickoIme}" />
                <DataGridTextColumn Header="Status" Width="*" Binding="{Binding StatusPrijave}" />
                <DataGridTextColumn Header="Port" Width="*" Binding="{Binding DodeljeniPort}" />
                <DataGridTextColumn Header="Role" Width="*" Binding="{Binding Role}" />
            </DataGrid.Columns>

        </DataGrid>

    </Grid>
</UserControl>
