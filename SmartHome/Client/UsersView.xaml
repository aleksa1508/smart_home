<UserControl x:Class="Client.UsersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Client"
             mc:Ignorable="d" 
             d:DesignHeight="370" d:DesignWidth="610">
    <Grid Background="#1D3557">
        <Grid.RowDefinitions>
            <RowDefinition Height="2*"></RowDefinition>
            <RowDefinition Height="11*"></RowDefinition>
            <RowDefinition Height="2*"></RowDefinition>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right">
            
        <ComboBox x:Name="RolesComboBox" Style="{StaticResource combo_box3}" HorizontalAlignment="Center" Margin="0,10,20,0"   SelectionChanged="ComboBox_SelectionChanged" >
            <ComboBoxItem Content="All users"/>
            <ComboBoxItem Content="Owner"/>
            <ComboBoxItem Content="User"/>
        </ComboBox>
            <ComboBox x:Name="StatusComboBox" Style="{StaticResource combo_box3}" HorizontalAlignment="Center" Margin="0,10,10,0"  SelectionChanged="ComboBox_SelectionChanged" >
            <ComboBoxItem Content="All status"/>
            <ComboBoxItem Content="Active"/>
            <ComboBoxItem Content="Inactive"/>
        </ComboBox>
        </StackPanel>
        <DataGrid x:Name="UsersDataGrid" 
                  Grid.Row="1"
          Margin="10,5,10,109"
    ColumnWidth="*"
    HorizontalScrollBarVisibility="Disabled"
          Height="240"
          ItemsSource="{Binding EntitiesView}"
          IsReadOnly="True"
          AutoGenerateColumns="False"
          Background="#1D3557"
          BorderThickness="0"
          GridLinesVisibility="None"
          HorizontalGridLinesBrush="#A8DADC"
          VerticalGridLinesBrush="#A8DADC"
          HeadersVisibility="Column" SelectionChanged="UsersDataGrid_SelectionChanged"
          Foreground="White">

            <!-- HEADER -->
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#457B9D"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="Padding" Value="10,5"/>
                    <Setter Property="HorizontalContentAlignment" Value="Center"/>

                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="DataGridColumnHeader">
                                <Border
                        CornerRadius="5"
                        Background="{TemplateBinding Background}"
                        BorderBrush="#A8DADC"
                        BorderThickness="1"
                        Padding="{TemplateBinding Padding}">

                                    <ContentPresenter 
                            Content="{TemplateBinding Content}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"/>

                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </DataGrid.ColumnHeaderStyle>

            <!-- ROW STYLE -->
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="Background" Value="#2F4769"/>

                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="DataGridRow">
                                <Border x:Name="RowBorder"
                            CornerRadius="8"
                            BorderBrush="#A8DADC"
                            BorderThickness="1,1,1,0" Height="25"
                            Background="{TemplateBinding Background}"
                            Opacity="0.95">

                                    <DataGridCellsPresenter/>

                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>

                    <!-- Hover -->
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#3A5A80"/>
                        </Trigger>
                    </Style.Triggers>

                </Style>
            </DataGrid.RowStyle>


            <!-- CELL -->
            <DataGrid.CellStyle>
                <Style TargetType="DataGridCell">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="0,0,0,0"/>
                    <Setter Property="BorderBrush" Value="#A8DADC"/>
                    <Setter Property="Padding" Value="8,4"/>

                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="DataGridCell">
                                <Border
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}">

                                    <ContentPresenter 
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </DataGrid.CellStyle>


            <!-- COLUMNS -->
            <DataGrid.Columns>
                <DataGridTextColumn Header="First name" Width="*" Binding="{Binding FirstName}" />
                <DataGridTextColumn Header="Last name" Width="*" Binding="{Binding LastName}" />
                <DataGridTextColumn Header="Username" Width="*" Binding="{Binding Username}" />
                <DataGridTextColumn Header="Status" Width="*" Binding="{Binding Status}" />
                <DataGridTextColumn Header="Port" Width="*" Binding="{Binding Port}" />
                <DataGridTextColumn Header="Role" Width="*" Binding="{Binding Role}" />
            </DataGrid.Columns>

        </DataGrid>
        <!-- ACTION PANEL — vidljiv samo kad je red selektovan i korisnik je ADMIN -->
        <Border x:Name="ActionPanel"
            Grid.Row="2"
            Visibility="Collapsed"
            Background="#2F4769"
            CornerRadius="10"
            Margin="10,0,10,10"
            Padding="15,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Info o selektovanom korisniku -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Selected: " Foreground="#A8DADC" FontWeight="Bold"/>
                    <TextBlock x:Name="SelectedUserText" Foreground="White"/>
                    <TextBlock Text="  |  Current role: " Foreground="#A8DADC" FontWeight="Bold"/>
                    <TextBlock x:Name="CurrentRoleText" Foreground="#FF60F360" FontWeight="Bold"/>
                </StackPanel>

                <!-- Odabir nove role -->
                <ComboBox x:Name="NewRoleComboBox"
                      Grid.Column="1"
                      Width="120"
                      Margin="10,-5"
                      VerticalAlignment="Center"
                      Style="{StaticResource combo_box3}">
                    <ComboBoxItem Content="OWNER"/>
                    <ComboBoxItem Content="USER"/>
                </ComboBox>

                <!-- Dugme za primjenu -->
                <Button x:Name="ChangeRoleButton"
                    Grid.Column="2"
                    Content="Change Role"
                    Width="110"
                    Height="35"
                    Cursor="Hand"
                    Click="ChangeRoleButton_Click"
                    VerticalAlignment="Center">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#457B9D"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                            CornerRadius="8"
                                            Padding="10,5">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#E63946"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>
