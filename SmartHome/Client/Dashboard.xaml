<Window x:Class="Client.Dashboard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:notifications="clr-namespace:Notification.Wpf.Controls;assembly=Notification.Wpf"
        xmlns:local="clr-namespace:Client"
        WindowStyle="None"
        MouseDown="Window_MouseDown"
        AllowsTransparency="True"
        Background="Transparent"
        Title="Dashboard">

    <Grid Width="800" Height="450">
        <notifications:NotificationArea HorizontalAlignment="Left" x:Name="WindowNotificationArea" Width="350" MaxItems="3" Panel.ZIndex="800" Position="TopCenter"/>
        <Rectangle Width="800" Height="450" RadiusX="20" RadiusY="20" Fill="#1D3557" Stroke="#FFA5C0F3"/>
        <StackPanel x:Name="DashboardStackPanel" Canvas.Top="7" Canvas.Left="180">
            <Grid Width="600" Height="60" Margin="150,0,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*"></ColumnDefinition>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" HorizontalAlignment="Left" Width="225">
                    <Label x:Name="Title" Foreground="White" FontSize="20" Width="232">Hello,Jack</Label>
                    <Label Foreground="White" FontSize="12" Margin="0,-10,0,0">Monitoring your home now</Label>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" Width="140">

                    <Button x:Name="ProfileButton" Width="30" Height="30" Background="Transparent" BorderThickness="0" Margin="10,0,10,0" ToolTip="View Profile" Click="ProfileButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border"
                    CornerRadius="18" BorderBrush="White" BorderThickness="1"
                    Background="{TemplateBinding Background}">

                                    <Viewbox Width="18" Height="18">
                                        <Path Fill="White"
                          Data="M12 12c2.7 0 5-2.3 5-5s-2.3-5-5-5-5 2.3-5 5 2.3 5 5 5zm0 2c-3.3 0-10 1.7-10 5v3h20v-3c0-3.3-6.7-5-10-5z"/>
                                    </Viewbox>
                                </Border>

                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Setter TargetName="border" Property="Background" Value="#2A4A73"/>
                                    </Trigger>

                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="border" Property="Opacity" Value="0.7"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Popup x:Name="ProfilePopup"
       Placement="Bottom" VerticalOffset="10" 
       PlacementTarget="{Binding ElementName=ProfileButton}"
       StaysOpen="False" AllowsTransparency="True">

                        <Border Background="#2F4769" BorderBrush="White" BorderThickness="1.4" CornerRadius="10" Padding="10">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="15"
                      ShadowDepth="2"
                      Opacity="0.4"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="{Binding FullName}" FontSize="15" Foreground="White" HorizontalAlignment="Center"/>

                                <Separator Background="White"/>

                                <Button x:Name="button_profile" Content="Edit profile"  FontSize="14" Foreground="White" Background="Transparent" Click="button_profile_Click">
                                    <Button.Template>

                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="border" Height="30"  Width="Auto"  BorderThickness="0,0,0,1.2" BorderBrush="White" Background="{TemplateBinding Background}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Cursor" Value="Hand"/>
                                                    <Setter TargetName="border" Property="Background" Value="#FF486892"/>
                                                </Trigger>

                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="border" Property="Opacity" Value="0.7"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>

                                    </Button.Template>
                                </Button>
                                <Button x:Name="button_password" Content="Change password"  FontSize="14"  Foreground="White" Background="Transparent" Click="button_password_Click">
                                    <Button.Template>

                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="border" Height="30"  Width="Auto" BorderThickness="0,0,0,1.2" BorderBrush="White" Background="{TemplateBinding Background}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Cursor" Value="Hand"/>
                                                    <Setter TargetName="border" Property="Background" Value="#FF486892"/>
                                                </Trigger>

                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="border" Property="Opacity" Value="0.7"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>

                                    </Button.Template>
                                </Button>
                                <Button x:Name="button_logout"  FontSize="14" Content="Logout" BorderThickness="0,0,0,1.2" BorderBrush="White" Foreground="White" Background="Transparent" Click="button_logout_Click">
                                    <Button.Template>

                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="border" Height="30"  Width="Auto" BorderThickness="0,0,0,1.2" BorderBrush="White" Background="{TemplateBinding Background}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Cursor" Value="Hand"/>
                                                    <Setter TargetName="border" Property="Background" Value="#FF486892"/>
                                                </Trigger>

                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="border" Property="Opacity" Value="0.7"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>

                                    </Button.Template>
                                </Button>
                            </StackPanel>
                        </Border>
                    </Popup>
                    <Button x:Name="button_minimize" Content="_" Style="{StaticResource button_minimize}" Click="button_minimize_Click"/>
                    <Button x:Name="button_close" Content="X" Style="{StaticResource button_close}" Click="button_close_Click"/>
                </StackPanel>
            </Grid>
        </StackPanel>
