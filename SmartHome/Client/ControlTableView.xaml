<UserControl x:Class="Client.ControlTableView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Client"
             mc:Ignorable="d" 
             d:DesignHeight="370" d:DesignWidth="610">
    <StackPanel  Background="#1D3557" >
        
        <Grid Width="300" Height="200" Margin="34,0,276,0">
            <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"></ColumnDefinition>
            <ColumnDefinition Width="2*"></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
        </Grid.RowDefinitions>
            <Label Grid.Row="0" Grid.Column="0" Content="Device:" Foreground="White" FontSize="17" Margin="10,12,0,0"/>
            <Label Grid.Row="1" Grid.Column="0" Content="Name:" Foreground="White" FontSize="17" Margin="10,12,0,0"/>
            <Label Grid.Row="2" Grid.Column="0" Content="Value:" Foreground="White" FontSize="17" Margin="10,12,0,0"/>
            <ComboBox x:Name="DeviceComboBox" Grid.Row="0" Grid.Column="1" Width="180" Height="30" Style="{StaticResource combo_box1}" ItemsSource="{Binding Devices}" DisplayMemberPath="Name"  SelectionChanged="DeviceComboBox_SelectionChanged"/>
            <ComboBox x:Name="FunctionComboBox" Grid.Row="1" Grid.Column="1" Style="{StaticResource combo_box2}"/>
            <TextBox x:Name="ValueTextBox" Grid.Row="2" Grid.Column="1" Style="{StaticResource txt_box}" IsEnabled="False"/>
            <Button x:Name="submit_button" Grid.Row="3" Grid.Column="1" HorizontalAlignment="Center" Foreground="White" Background="#4C5FF2" FontSize="20" ToolTip="Submit" Click="submit_button_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Height="30" CornerRadius="20" Width="180" Background="{TemplateBinding Background}">
                            <ContentPresenter Content="Submit" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter  Property="Cursor" Value="Hand"/>
                                <Setter TargetName="border" Property="Background" Value="#FF2B42F3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>
        <Label Content="Last Logs" Foreground="White" FontSize="17" Margin="10,0,0,0"/>
        <DataGrid x:Name="LogsDataGrid" 
      Margin="5,0,5,0"
ColumnWidth="*"
HorizontalScrollBarVisibility="Disabled"
                  ItemsSource="{Binding CommandRegister}"
      Height="126"
      IsReadOnly="True"
      AutoGenerateColumns="False"
      Background="#1D3557"
      BorderThickness="0"
      GridLinesVisibility="None"
      HorizontalGridLinesBrush="#A8DADC"
      VerticalGridLinesBrush="#A8DADC"
      HeadersVisibility="Column"
      Foreground="White">

            <!-- HEADER -->
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#457B9D"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="Padding" Value="10,5"/>
                    <Setter Property="HorizontalContentAlignment" Value="Center"/>

                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="DataGridColumnHeader">
                                <Border
                    CornerRadius="5"
                    Background="{TemplateBinding Background}"
                    BorderBrush="#A8DADC"
                    BorderThickness="1"
                    Padding="{TemplateBinding Padding}">

                                    <ContentPresenter 
                        Content="{TemplateBinding Content}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"/>

                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </DataGrid.ColumnHeaderStyle>

            <!-- ROW STYLE -->
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="Background" Value="#2F4769"/>

                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="DataGridRow">
                                <Border x:Name="RowBorder"
                        CornerRadius="8"
                        BorderBrush="#A8DADC"
                        BorderThickness="1,1,1,0" Height="25"
                        Background="{TemplateBinding Background}"
                        Opacity="0.95">

                                    <DataGridCellsPresenter/>

                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>

                    <!-- Hover -->
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#3A5A80"/>
                        </Trigger>
                    </Style.Triggers>

                </Style>
            </DataGrid.RowStyle>


            <!-- CELL -->
            <DataGrid.CellStyle>
                <Style TargetType="DataGridCell">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="0,0,0,0"/>
                    <Setter Property="BorderBrush" Value="#A8DADC"/>
                    <Setter Property="Padding" Value="8,4"/>

                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="DataGridCell">
                                <Border
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}">

                                    <ContentPresenter 
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </DataGrid.CellStyle>


            <!-- COLUMNS -->
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Width="*" Binding="{Binding ID}" />
                <DataGridTextColumn Header="Date and Time" Width="3*" Binding="{Binding CreationDate}" />
                <DataGridTextColumn Header="Log" Width="7*" Binding="{Binding Log}" />
            </DataGrid.Columns>

        </DataGrid>
    </StackPanel>
</UserControl>
