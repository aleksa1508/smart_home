<Application x:Class="Client.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Client"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <Style x:Key="button_minimize" TargetType="Button">
            <Setter Property="FontWeight" Value="Bold"></Setter>
            <Setter Property="Foreground" Value="Black"></Setter>
            <Setter Property="Cursor" Value="Hand"></Setter>
            <Setter Property="Content" Value="_"></Setter>
            <Setter Property="ToolTip" Value="Minimize"></Setter>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Height="30" CornerRadius="20" Width="30" Margin="0,0,10,0" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Background" Value="#B5C0EF"></Setter>
            <Style.Triggers >
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#DADAE5"></Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="button_close" TargetType="Button">
            <Setter Property="FontWeight" Value="Bold"></Setter>
            <Setter Property="Foreground" Value="Black"></Setter>
            <Setter Property="Cursor" Value="Hand"></Setter>
            <Setter Property="Content" Value="X"></Setter>
            <Setter Property="ToolTip" Value="Close"></Setter>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Height="30" CornerRadius="20" Width="30" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Background" Value="#EF7070"></Setter>
            <Style.Triggers >
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EA2626"></Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="txt_box_input" TargetType="TextBox">
            <Setter Property="Foreground" Value="White"></Setter>
            <Setter Property="Background" Value="#324766"></Setter>
            <Setter Property="BorderBrush" Value="#324766"></Setter>
            <Setter Property="Cursor" Value="IBeam"></Setter>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox"> 
                        <Border Height="40" CornerRadius="20" Width="300" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ScrollViewer x:Name="PART_ContentHost" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="15 0 0 0 "/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers >
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderThickness" Value="2"></Setter>
                    <Setter Property="BorderBrush" Value="#60A5FA"></Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="password_box" TargetType="PasswordBox">
            <Setter Property="Foreground" Value="White"></Setter>
            <Setter Property="Background" Value="#324766"></Setter>
            <Setter Property="BorderBrush" Value="#324766"></Setter>
            <Setter Property="Cursor" Value="IBeam"></Setter>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border x:Name="border" Height="40" CornerRadius="20" Width="300" Background="{TemplateBinding Background}"  BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ScrollViewer x:Name="PART_ContentHost" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="15 0 0 0 "/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers >
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderThickness" Value="2"></Setter>
                    <Setter Property="BorderBrush" Value="#60A5FA"></Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="menu_button" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"></Setter>
            <Setter Property="Background" Value="#2F4769"></Setter>
            

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Height="60" Width="160" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers >
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#6291a9"></Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="device_button" TargetType="Button">
            <Setter Property="FontWeight" Value="Light"></Setter>
            <Setter Property="Foreground" Value="White"></Setter>
            <Setter Property="Cursor" Value="Hand"></Setter>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Height="30" CornerRadius="20" Width="180" Margin="0,0,10,0" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>

                            <!-- 🔵 AKTIVNO dugme -->
                            <Trigger Property="Tag" Value="active">
                                <Setter TargetName="border" Property="Background" Value="#4C5FF2"/>
                            </Trigger>

                            <!-- 🖱️ HOVER -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3A5A80"/>
                            </Trigger>

                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Background" Value="#FF4773B2"></Setter>
            
        </Style>
        <Style x:Key="device_tab" TargetType="Button">
            <Setter Property="FontWeight" Value="Light"></Setter>
            <Setter Property="Foreground" Value="White"></Setter>
            <Setter Property="Cursor" Value="Hand"></Setter>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Height="30" CornerRadius="20" Width="120" Margin="0,0,10,0" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>

                            <!-- 🔵 AKTIVNO dugme -->
                            <Trigger Property="Tag" Value="active">
                                <Setter TargetName="border" Property="Background" Value="#4C5FF2"/>
                            </Trigger>

                            <!-- 🖱️ HOVER -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3A5A80"/>
                            </Trigger>

                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Background" Value="#FF4773B2"></Setter>
            
        </Style>
        <Style x:Key="txt_box" TargetType="TextBox">
            <Setter Property="Foreground" Value="White"></Setter>
            <Setter Property="Background" Value="#324766"></Setter>
            <Setter Property="BorderBrush" Value="#324766"></Setter>
            <Setter Property="Cursor" Value="IBeam"></Setter>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Height="30" CornerRadius="20" Width="180" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ScrollViewer x:Name="PART_ContentHost" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="15 0 0 0 "/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers >
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderThickness" Value="2"></Setter>
                    <Setter Property="BorderBrush" Value="#60A5FA"></Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        
        <Style x:Key="combo_box1" TargetType="ComboBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#324766"/>
            <Setter Property="BorderBrush" Value="#324766"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,2"/>
            <Setter Property="Cursor" Value="Hand"/>

            
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>

                            <!-- MAIN -->
                            <Border x:Name="MainBorder"
                            CornerRadius="20"
                            Height="30" Width="180"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition Width="30"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- SELECTED ITEM -->
                                    <ContentPresenter 
                                Margin="10,0,0,0"
                                VerticalAlignment="Center"
                                 Content="{Binding SelectedItem.Name, RelativeSource={RelativeSource TemplatedParent}}"/>

                                    <!-- ARROW -->
                                    <TextBlock Grid.Column="1"
                                       Text="▼"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>

                                    <!-- 🔥 KLIK PREKO CIJELOG -->
                                    <ToggleButton
    Grid.ColumnSpan="2"
    Background="Transparent"
    BorderThickness="0"
    Cursor="Hand"
    IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                                        <ToggleButton.Style>
                                            <Style TargetType="ToggleButton">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ToggleButton">
                                                            <Border Background="Transparent">
                                                                <ContentPresenter/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ToggleButton.Style>
                                    </ToggleButton>
                                </Grid>
                            </Border>

                            <!-- DROPDOWN -->
                            <Popup 
                        IsOpen="{TemplateBinding IsDropDownOpen}"
                        Placement="Bottom"
                        PlacementTarget="{Binding ElementName=MainBorder}"
                        AllowsTransparency="True"
                        Focusable="False"
                        PopupAnimation="Fade">

                                <Border 
                            Background="#2F4769"
                            CornerRadius="10"
                            Margin="0,5,0,0"
                            BorderBrush="#A8DADC"
                            BorderThickness="1"
                            Width="{Binding ActualWidth, ElementName=MainBorder}">

                                    <ScrollViewer MaxHeight="200">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>

                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="combo_box2" TargetType="ComboBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#324766"/>
            <Setter Property="BorderBrush" Value="#324766"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,2"/>
            <Setter Property="Cursor" Value="Hand"/>

            
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>

                            <!-- MAIN -->
                            <Border x:Name="MainBorder"
                            CornerRadius="20"
                            Height="30" Width="180"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition Width="30"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- SELECTED ITEM -->
                                    <ContentPresenter 
                                Margin="10,0,0,0"
                                VerticalAlignment="Center"
                                Content="{Binding SelectedItem.Value.Name, RelativeSource={RelativeSource TemplatedParent}}"/>

                                    <!-- ARROW -->
                                    <TextBlock Grid.Column="1"
                                       Text="▼"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>

                                    <!-- 🔥 KLIK PREKO CIJELOG -->
                                    <ToggleButton
    Grid.ColumnSpan="2"
    Background="Transparent"
    BorderThickness="0"
    Cursor="Hand"
    IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                                        <ToggleButton.Style>
                                            <Style TargetType="ToggleButton">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ToggleButton">
                                                            <Border Background="Transparent">
                                                                <ContentPresenter/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ToggleButton.Style>
                                    </ToggleButton>
                                </Grid>
                            </Border>

                            <!-- DROPDOWN -->
                            <Popup 
                        IsOpen="{TemplateBinding IsDropDownOpen}"
                        Placement="Bottom"
                        PlacementTarget="{Binding ElementName=MainBorder}"
                        AllowsTransparency="True"
                        Focusable="False"
                        PopupAnimation="Fade">

                                <Border 
                            Background="#2F4769"
                            CornerRadius="10"
                            Margin="0,5,0,0"
                            BorderBrush="#A8DADC"
                            BorderThickness="1"
                            Width="{Binding ActualWidth, ElementName=MainBorder}">

                                    <ScrollViewer MaxHeight="200">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>

                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Application.Resources>
</Application>
