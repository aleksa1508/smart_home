<UserControl x:Class="Client.SmartRulesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Client"
             mc:Ignorable="d" 
             d:DesignHeight="370" d:DesignWidth="610">
    <Grid Background="#1D3557">
        <StackPanel>
                    <Button x:Name="add_rule_button" HorizontalAlignment="Right" Foreground="White" Background="#4C5FF2" FontSize="20" Margin="0,10,10,10" ToolTip="Add new rule" Click="add_rule_button_Click">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border" Height="30" CornerRadius="20" Width="180" Background="{TemplateBinding Background}">
                        <ContentPresenter Content="Add new rule" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter  Property="Cursor" Value="Hand"/>
                            <Setter TargetName="border" Property="Background" Value="#FF2B42F3"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>
        <ItemsControl ItemsSource="{Binding SmartRules}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>

                    <Border Background="#2A4A75"
        CornerRadius="10"
        Padding="12"
        Margin="0,0,0,10">

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!-- LEFT SIDE -->
                            <StackPanel Grid.Column="0">

                                <!-- TITLE -->
                                <TextBlock Text="{Binding Name}"
                       FontSize="18"
                       FontWeight="Bold"
                       Foreground="White"/>

                                <!-- DESCRIPTION (aligned under title) -->
                                <TextBlock Text="{Binding Description}"
                       Margin="0,4,0,0"
                       HorizontalAlignment="Left"
                       TextWrapping="Wrap"
                       Foreground="#CCCCCC"
                       Width="350"/>
                            </StackPanel>

                            <!-- TOGGLE -->
                            <ToggleButton Grid.Column="1"
                      Width="70"
                      Height="30"
                      Margin="15,0,0,0"
                      IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                      Checked="ToggleButton_Checked"
                      Unchecked="ToggleButton_Unchecked"
                      Tag="{Binding}">

                                <ToggleButton.Style>
                                    <Style TargetType="ToggleButton">

                                        <Setter Property="Content" Value="OFF"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="Background" Value="#555"/>

                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ToggleButton">
                                                    <Border x:Name="bg"
                                        CornerRadius="5"
                                        Background="{TemplateBinding Background}"
                                        Padding="5"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">

                                                        <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                                    </Border>

                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsChecked" Value="True">
                                                            <Setter TargetName="bg" Property="Background" Value="#4CAF50"/>
                                                            <Setter Property="Content" Value="ON"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>

                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>

                                    </Style>
                                </ToggleButton.Style>

                            </ToggleButton>

                        </Grid>
                    </Border>

                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
        </StackPanel>

    </Grid>
</UserControl>
