<UserControl x:Class="Client.NewUserView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Client"
             mc:Ignorable="d" 
             d:DesignHeight="370" d:DesignWidth="610">
    <Grid Background="#1D3557">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="2*"/>
        </Grid.RowDefinitions>

        <!-- LIJEVA KOLONA — First Name, Last Name, Role -->
        <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
            <Label Content="First Name:" Foreground="White" FontSize="15" Width="100"/>
            <TextBox x:Name="FirstNameTextBox" Style="{StaticResource txt_box}"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
            <Label Content="Last Name:" Foreground="White" FontSize="15" Width="100"/>
            <TextBox x:Name="LastNameTextBox" Style="{StaticResource txt_box}"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
            <Label Content="Role:" Foreground="White" FontSize="15" Width="100"/>
            <ComboBox x:Name="RoleComboBox" Style="{StaticResource combo_box3}" Width="180">
                <ComboBoxItem Content="USER"/>
                <ComboBoxItem Content="OWNER"/>
            </ComboBox>
        </StackPanel>

        <!-- DESNA KOLONA — Username, Password, slika -->
        <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
            <Label Content="Username:" Foreground="White" FontSize="15" Width="100"/>
            <TextBox x:Name="UsernameTextBox" Style="{StaticResource txt_box}"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
            <Label Content="Password:" Foreground="White" FontSize="15" Width="100"/>
            <PasswordBox x:Name="PasswordBox" Style="{StaticResource password_box}" Width="180" Height="30"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                    Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock x:Name="ErrorText" Foreground="#E63946" FontSize="13" 
                       VerticalAlignment="Center" Margin="0,0,20,0" Visibility="Collapsed"/>
            <Button x:Name="add_user_button"  Style="{StaticResource device_button}"  Content="Add new user"  Width="260" Height="40" Click="add_user_button_Click"/>
        </StackPanel>

    </Grid>
</UserControl>
