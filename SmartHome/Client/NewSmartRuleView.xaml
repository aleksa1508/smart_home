<UserControl x:Class="Client.NewSmartRuleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Client"
             mc:Ignorable="d" 
                       d:DesignHeight="370" d:DesignWidth="610">
    <Grid Background="#1D3557">
        <StackPanel>
            <StackPanel Orientation="Horizontal">
            <Grid Width="350" Height="300" Margin="0,0,0,0" HorizontalAlignment="Left">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"></ColumnDefinition>
                    <ColumnDefinition Width="2*"></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"></RowDefinition>
                    <RowDefinition Height="*"></RowDefinition>
                    <RowDefinition Height="*"></RowDefinition>
                    <RowDefinition Height="*"></RowDefinition>
                    <RowDefinition Height="*"></RowDefinition>
                    <RowDefinition Height="*"></RowDefinition>
                    <RowDefinition Height="*"></RowDefinition>
                </Grid.RowDefinitions>
                <Label Grid.Row="0" Grid.Column="0" Content="Rule name:" Foreground="White" FontSize="17" Margin="10,8,0,0"/>
                <Label Grid.Row="1" Grid.Column="0" Content="Description:" Foreground="White" FontSize="17" Margin="10,8,0,0"/>
                <Label Grid.Row="2" Grid.Column="0" Content="Group:" Foreground="White" FontSize="17" Margin="10,8,0,0"/>
                <Label Grid.Row="3" Grid.Column="0" Content="Device:" Foreground="White" FontSize="17" Margin="10,8,0,0"/>
                <Label Grid.Row="4" Grid.Column="0" Content="Name:" Foreground="White" FontSize="17" Margin="10,8,0,0"/>
                <Label Grid.Row="5" Grid.Column="0" Content="Value:" Foreground="White" FontSize="17" Margin="10,8,0,0"/>
                <TextBox x:Name="RuleNameTextBox" Grid.Row="0" Grid.Column="1" Style="{StaticResource txt_box}"/>
                <TextBox x:Name="DesriptionTextBox" Grid.Row="1" Grid.Column="1" Style="{StaticResource txt_box}"/>
                    <ComboBox x:Name="ScopeComboBox" Grid.Row="2" Grid.Column="1" Style="{StaticResource combo_box2}" SelectionChanged="ScopeComboBox_SelectionChanged">
                        <ComboBoxItem Content="Single Device"/>
                        <ComboBoxItem Content="All Lights"/>
                        <ComboBoxItem Content="All Doors"/>
                        <ComboBoxItem Content="All Climates"/>
                    </ComboBox>
                    <ComboBox x:Name="DeviceComboBox" Grid.Row="3" Grid.Column="1" Width="180" Height="30" Style="{StaticResource combo_box1}" ItemsSource="{Binding Devices}" DisplayMemberPath="Name"  SelectionChanged="DeviceComboBox_SelectionChanged"/>
                <ComboBox x:Name="FunctionComboBox" IsEnabled="False" Grid.Row="4" Grid.Column="1" Style="{StaticResource combo_box2}"  DisplayMemberPath="Value.Name" SelectionChanged="FunctionComboBox_SelectionChanged"/>
                <TextBox x:Name="ValueTextBox" Grid.Row="5" Grid.Column="1" Style="{StaticResource txt_box}"/>
                    
                    <Button x:Name="action_button" Grid.Row="6" Grid.Column="1" HorizontalAlignment="Center" Foreground="White" Background="#4C5FF2" FontSize="20" ToolTip="Add action" Click="action_button_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Height="30" CornerRadius="20" Width="180" Background="{TemplateBinding Background}">
                                <ContentPresenter Content="Add action" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter  Property="Cursor" Value="Hand"/>
                                    <Setter TargetName="border" Property="Background" Value="#FF2B42F3"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
                <StackPanel>
                    <Label Content="Actions:" Foreground="White" FontSize="17" HorizontalAlignment="Center"/>
                    <ListBox x:Name="ActionsListBox"
         Height="250"
         Width="250"
         Background="#1D3557"
         BorderBrush="White"
         BorderThickness="1"
         Foreground="White"
         Padding="5">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#324766" CornerRadius="10" Padding="8" Margin="5">
                                <StackPanel Width="170">
                                    <TextBlock Text="{Binding Device.Name}" Foreground="White" FontWeight="Bold"/>
                                        <TextBlock>
                                             <Run Text="Function: "/>
                                             <Run Text="{Binding FunctionName}" FontWeight="Bold"/>
                                        </TextBlock>

                                        <TextBlock Margin="0,2,0,0">
                                            <Run Text="Value: "/>
                                            <Run Text="{Binding Value}" FontWeight="Bold"/>
                                        </TextBlock>
                                    </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                </StackPanel>
            </StackPanel>
            <Button x:Name="save_button" HorizontalAlignment="Center" Foreground="White" Background="#4C5FF2" FontSize="20" Margin="-140,10,0,0" ToolTip="Save" Click="save_button_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Height="30" CornerRadius="20" Width="180" Background="{TemplateBinding Background}">
                            <ContentPresenter Content="Save smart rule" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter  Property="Cursor" Value="Hand"/>
                                <Setter TargetName="border" Property="Background" Value="#FF2B42F3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
